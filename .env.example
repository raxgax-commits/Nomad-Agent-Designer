# Base URL for your n8n webhooks. All Claude / Flux / Drive secrets live in n8n, never here.
# Example (n8n Cloud): https://your-tenant.app.n8n.cloud/webhook
VITE_N8N_BASE_URL=https://your-tenant.app.n8n.cloud/webhook

# Optional shared secret sent as X-Nomads-Key header on every request.
# If set, configure the same value on each n8n webhook node's "Header Auth" credential.
VITE_N8N_SHARED_KEY=
